    ],
    "hints": [
        "Consider using a stack or recursion for the DFS implementation.",
        "Be mindful of already visited nodes to avoid cycles.",
        "Think about how to represent your graph adequately.",
        "Try to visualize the traversal to better understand the order of visiting nodes."
    ],
